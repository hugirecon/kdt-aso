# KDT Aso - Environment Configuration
# Copy this file to .env and fill in ALL required values

# ============================================================
# REQUIRED
# ============================================================

# Anthropic API key for AI agents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT Secret — GENERATE A UNIQUE ONE, DO NOT USE DEFAULT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ============================================================
# SERVER
# ============================================================

PORT=3001
NODE_ENV=production

# ============================================================
# SECURITY
# ============================================================

# CORS: comma-separated list of allowed origins (in addition to localhost)
# Example: https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=

# IP Allowlist: enable to restrict access to specific IPs only
IP_ALLOWLIST_ENABLED=false
# Comma-separated IPs (only used when allowlist is enabled)
ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# Trust proxy (set to true if behind nginx/load balancer)
TRUST_PROXY=false

# ============================================================
# PROPERTY / AGENT INSTANCE CONFIG
# ============================================================

# Unique property identifier (for multi-instance deployments)
PROPERTY_ID=
# Agent instance name
AGENT_INSTANCE_ID=
# Central server URL (for property registration)
CENTRAL_SERVER_URL=

# ============================================================
# OPTIONAL
# ============================================================

# ElevenLabs API key for voice synthesis
ELEVENLABS_API_KEY=

# Dashboard URL (for CORS — added automatically if set)
DASHBOARD_URL=http://localhost:3001

# Docker compose project name
COMPOSE_PROJECT_NAME=kdt-aso

# Deployment environment
DEPLOY_ENV=production
