# KDT Aso - Development Dockerfile
# Hot-reload enabled for development

FROM node:20-alpine

# Security: add non-root user (even in dev)
RUN addgroup -g 1001 -S kdt && \
    adduser -S kdt -u 1001 -G kdt

WORKDIR /app

# Install dependencies for both backend and dashboard
COPY package*.json ./
RUN npm install

COPY dashboard/package*.json ./dashboard/
RUN cd dashboard && npm install

# Copy application code
COPY . .

# Install nodemon for hot-reload
RUN npm install -g nodemon concurrently

# Create required dirs and set ownership
RUN mkdir -p logs memory documents backups audio config/keys && \
    chown -R kdt:kdt /app

# Run as non-root even in dev
USER kdt

# Expose ports
EXPOSE 3001 3002

# Start both backend and dashboard with hot-reload
CMD ["concurrently", "--kill-others", "\"nodemon --watch core core/index.js\"", "\"cd dashboard && npm run dev -- --host 0.0.0.0\""]
